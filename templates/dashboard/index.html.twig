{% extends 'base.html.twig' %}

{% block title %}User Data Dashboard{% endblock %}

{% set genderLabels = [] %}
{% set genderCounts = [] %}

{% set roleLabels = [] %}
{% set roleCounts = [] %}

{% for item in summary %}
    {% if item.metric == 'gender' %}
        {% set genderLabels = genderLabels|merge([item.metric_value]) %}
        {% set genderCounts = genderCounts|merge([item.total_count]) %}
    {% endif %}

    {% if item.metric == 'role' %}
        {% set roleLabels = roleLabels|merge([item.metric_value]) %}
        {% set roleCounts = roleCounts|merge([item.total_count]) %}
    {% endif %}
{% endfor %}

{% block body %}
<div style="max-width: 1100px; margin: 40px auto; font-family: Arial, sans-serif;">
    <h1>User Data ETL Dashboard</h1>

    {% if selectedProcess %}
        <p>
            <strong>Selected Process:</strong> #{{ selectedProcess.id }} |
            <strong>Date:</strong> {{ selectedProcess.execution_date }} |
            <strong>Total Records:</strong> {{ selectedProcess.total_records }}
        </p>
    {% endif %}

    <h2>ETL Executions</h2>

    <table border="1" cellpadding="8" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>ID</th>
                <th>Execution Date</th>
                <th>Total Records</th>
                <th>Raw File</th>
                <th>ETL File</th>
                <th>Summary File</th>
            </tr>
        </thead>
        <tbody>
            {% for process in processes %}
                <tr>
                    <td>{{ process.id }}</td>
                    <td>{{ process.execution_date }}</td>
                    <td>{{ process.total_records }}</td>
                    <td>{{ process.raw_file_name }}</td>
                    <td>{{ process.etl_file_name }}</td>
                    <td>{{ process.summary_file_name }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
    <br/>
    <form method="get" action="{{ path('app_dashboard') }}">
    <label for="processId"><strong>Select Process:</strong></label>
    <select name="processId" id="processId" onchange="this.form.submit()">
        {% for process in processes %}
            <option value="{{ process.id }}" {% if selectedProcess and process.id == selectedProcess.id %}selected{% endif %}>
                Process #{{ process.id }} - {{ process.execution_date }}
            </option>
        {% endfor %}
    </select>
    </form>

    <h2>Charts</h2>

    <div style="display:flex; gap:30px; margin-bottom:30px;">
        <div style="width:45%;">
            <canvas id="genderChart"></canvas>
        </div>

        <div style="width:45%;">
            <canvas id="roleChart"></canvas>
        </div>
    </div>

    <h2>Summary</h2>

    <table border="1" cellpadding="8" cellspacing="0" width="100%">
        <thead>
            <tr>
                <th>Metric</th>
                <th>Value</th>
                <th>Count</th>
            </tr>
        </thead>
        <tbody>
            {% for item in summary %}
                <tr>
                    <td>{{ item.metric }}</td>
                    <td>{{ item.metric_value }}</td>
                    <td>{{ item.total_count }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const genderChart = document.getElementById('genderChart');

new Chart(genderChart, {
    type: 'pie',
    data: {
        labels: {{ genderLabels|json_encode|raw }},
        datasets: [{
            data: {{ genderCounts|json_encode|raw }}
        }]
    }
});

const roleChart = document.getElementById('roleChart');

new Chart(roleChart, {
    type: 'bar',
    data: {
        labels: {{ roleLabels|json_encode|raw }},
        datasets: [{
            label: 'Users',
            data: {{ roleCounts|json_encode|raw }}
        }]
    }
});

</script>

{% endblock %}